    "@rollup/plugin-typescript": "^12.1.0",
    "@types/node": "^20.16.0",
    "rollup": "^4.24.0",
    "sharp": "^0.33.5",
    "tslib": "^2.7.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
