{
  "$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
  "Name": "AI Usage Monitor",
  "Version": "0.1.0.0",
  "Author": "Hudson Brendon",
  "Description": "Live Claude and Codex subscription usage — rolling 5-hour and weekly windows, on your Stream Deck.",
  "Category": "AI Usage Monitor",
  "CategoryIcon": "imgs/plugin/category",
  "Icon": "imgs/plugin/icon",
  "URL": "https://github.com/hudsonbrendon/ai-usage-streamdeck",
  "SDKVersion": 2,
  "UUID": "com.hudsonbrendon.ai-usage",
  "Software": {
    "MinimumVersion": "6.5"
  },
  "OS": [
    {
      "Platform": "mac",
      "MinimumVersion": "12"
    },
    {
      "Platform": "windows",
      "MinimumVersion": "10"
    }
  ],
  "Nodejs": {
    "Version": "20",
    "Debug": "enabled"
  },
  "CodePath": "bin/plugin.js",
  "Actions": [
    {
      "Name": "Claude Usage",
      "UUID": "com.hudsonbrendon.ai-usage.claude",
      "Icon": "imgs/actions/claude",
      "Tooltip": "Show Claude (Anthropic) subscription usage.",
      "Controllers": [
        "Keypad"
      ],
      "PropertyInspectorPath": "ui/settings.html",
      "States": [
        {
          "Image": "imgs/actions/claude-key",
          "TitleAlignment": "middle"
        }
      ]
    },
    {
      "Name": "Codex Usage",
      "UUID": "com.hudsonbrendon.ai-usage.codex",
      "Icon": "imgs/actions/codex",
      "Tooltip": "Show Codex (OpenAI) subscription usage.",
      "Controllers": [
        "Keypad"
      ],
      "PropertyInspectorPath": "ui/settings.html",
      "States": [
        {
          "Image": "imgs/actions/codex-key",
          "TitleAlignment": "middle"
        }
      ]
    }
  ]
}